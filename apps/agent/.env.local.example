# ============================================================
# AgentHub (apps/agent) — copy to .env.local and fill in.
# Only Supabase + Anthropic are required to boot. Everything
# else unlocks a specific feature and can be added later.
# ============================================================

# ---- Required: Supabase ----
# Project Settings → API  (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Required: Anthropic (the AI agent) ----
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---- Required: public URL of THIS app ----
# Local dev = http://localhost:3001 ; prod = your Vercel URL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ---- Scheduled jobs (recommended) ----
# Any random string. Vercel Cron sends it as a Bearer token.
CRON_SECRET=change-me-to-a-random-string

# ---- Telegram channel (easiest to start) ----
# No env var needed — paste the @BotFather token into the dashboard UI.

# ---- WhatsApp channel (Meta Cloud API) ----
# No env var needed — paste access token / phone number id / verify token
# into the dashboard UI per channel.

# ---- Billing: Stripe (optional) ----
# https://dashboard.stripe.com/apikeys + create 3 recurring prices
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# ---- Web search tool (optional) — https://serper.dev ----
SERPER_API_KEY=

# ---- Image generation tool (optional, OpenAI-compatible) ----
IMAGE_API_URL=https://api.openai.com/v1/images/generations
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-1

# ---- Voice: speech-to-text (optional, OpenAI-compatible) ----
STT_API_URL=https://api.openai.com/v1/audio/transcriptions
STT_API_KEY=
STT_MODEL=whisper-1

# ---- Voice: text-to-speech (optional) ----
TTS_API_URL=
TTS_API_KEY=
TTS_MODEL=tts-1
TTS_VOICE=alloy

# ---- Google Workspace (optional) ----
# https://console.cloud.google.com → OAuth client (Web).
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
