# ============================================================
# VanTrack Platform — Environment Variables
# Copy to .env.local — NEVER commit .env.local
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google APIs
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key
GOOGLE_PLACES_API_KEY=your-google-places-key

# Anthropic (AI Sales Agent)
ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@foodtaxi.co.uk

# SMS (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+44...

# Food Standards Agency
FSA_API_BASE_URL=https://api.ratings.food.gov.uk

# Companies House
COMPANIES_HOUSE_API_KEY=your-key

# ============================================================
# AgentHub — WhatsApp / Telegram AI Agent Platform (apps/agent)
# ============================================================

# App URL of the agent app (used to build webhook + OAuth redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Cron protection for scheduled jobs runner (apps/agent/api/cron/run-jobs)
CRON_SECRET=change-me

# Stripe subscription price ids (one per paid plan)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# Web search tool (Serper.dev compatible)
SERPER_API_KEY=

# Image generation tool (OpenAI-compatible /images endpoint)
IMAGE_API_URL=https://api.openai.com/v1/images/generations
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-1

# Voice: speech-to-text (OpenAI-compatible /audio/transcriptions)
STT_API_URL=https://api.openai.com/v1/audio/transcriptions
STT_API_KEY=
STT_MODEL=whisper-1

# Voice: text-to-speech (optional, OpenAI-compatible /audio/speech)
TTS_API_URL=
TTS_API_KEY=
TTS_MODEL=tts-1
TTS_VOICE=alloy

# Google Workspace OAuth (Gmail, Calendar, Sheets, Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
